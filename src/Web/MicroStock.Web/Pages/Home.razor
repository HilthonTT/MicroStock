@page "/"
@using System.Security.Claims

<PageTitle>Home</PageTitle>

<AuthorizeView>
    <Authorized>
        <h1>Hello, @context.User.Identity?.Name!</h1>
        <p>Welcome back!</p>

        <h3>Your info:</h3>
        <ul>
            <li><strong>Name:</strong> @context.User.Identity?.Name</li>
            <li><strong>Authenticated:</strong> @context.User.Identity?.IsAuthenticated</li>
            <li><strong>Email:</strong> @context.User.FindFirst("email")?.Value</li>
            <li>
                <strong>Role(s):</strong>
                @(string.Join(", ", context.User.FindAll(ClaimTypes.Role).Select(c => c.Value)))
            </li>
            <li><strong>Sub (User ID):</strong> @context.User.FindFirst("sub")?.Value</li>
        </ul>

        <p><em>You are logged in</em></p>
    </Authorized>
    <NotAuthorized>
        <h1>Hello, world!</h1>
        <p>You are currently <strong>logged out</strong>.</p>
        <a href="/login">Log in</a>
    </NotAuthorized>
</AuthorizeView>