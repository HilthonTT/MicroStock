{
  "ConnectionStrings": {
    "Database": "Host=microstock.database;Port=5432;Database=microstock;Username=postgres;Password=postgres;Include Error Detail=true",
    "Cache": "microstock.redis:6379,abortConnect=false"
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console",
      "Serilog.Sinks.Seq"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Information"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "Seq",
        "Args": {
          "serverUrl": "http://microstock.seq:5341"
        }
      }
    ],
    "Enrich": [
      "FromLogContext",
      "WithMachineName",
      "WithThreadId"
    ],
    "Properties": {
      "Application": "MicroStock.Api"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173"
    ]
  },
  "Jwt": {
    "Key": "your-secret-key-here-that-should-also-be-fairly-long",
    "Issuer": "microstock.api",
    "Audience": "microstock.app",
    "ExpirationInMinutes": 30,
    "RefreshTokenExpirationDays": 7
  }
}
